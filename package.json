{
  "name": "boilerplater",
  "displayName": "Br-Zueira's Boilerplater",
  "repository": {
    "type": "git",
    "url": "https://github.com/Br-Zueira/Boilerplater.git"
  },
  "publisher": "br-zueira",
  "description": "Extension to storage boilerplate snippets so they can be easily reused later",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "boilerplater.pickupText",
        "title": "Boilerplater: Pickup Text"
      },
      {
        "command": "boilerplater.openWebView",
        "title": "Boilerplater: Open Web View"
      }
    ],
    "keybindings": [
      {
        "command": "boilerplater.pickupText",
        "key": "ctrl+u",
        "mac": "cmd+u",
        "when": "editorTextFocus"
      },
      {
        "command": "boilerplater.openWebView",
        "key": "ctrl+alt+u",
        "mac": "cmd+alt+u"
      }
    ],
    "configuration":{
      "title": "Boilerplater custom template values",
      "properties": {
        "boilerplater.customVariables": {
          "type": "array",
          "markdownDescription": "Define custom variables. [Open Json](command:workbench.action.openSettingsJson) to define them.",
          "default": [
            {
              "name": "MY_VARIABLE",
              "value": "return 2 + 3;",
              "description": "This variable adds 2 numbers and returns 5"
            },
            {
            "name": "MY_FUNC_VAR",
            "value": "return (first, second) => first + second;",
            "description": "This variable adds 2 custom numbers"
            }
          ],
          "items": {
            "type": "object",
            "required": ["name", "value"],
            "properties": {
              "name": {
                "type": "string",
                "description": "The variable name that will become accessible inside templating tags (keep it simple to avoid errors!)"
              },
              "value": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "The JavaScript code to be evaluated. It should return either a string or something that returns a string. It can access a few external dependencies such as vscode."
              },
              "description": {
                "type": "string",
                "description": "(Optional) Describe what your variable represents and returns."
              }
            }
          }
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "node build.mjs",
    "watch": "node build.mjs --watch",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "package": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.20.0",
    "@types/sql.js": "^1.4.11",
    "@types/vscode": "^1.120.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.28.1",
    "esbuild-plugin-copy": "^2.1.1",
    "eslint": "^9.39.3",
    "shx": "^0.4.0",
    "sql.js": "^1.14.1",
    "tom-select": "^2.6.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
