{
  "name": "boilerplater",
  "displayName": "Boilerplater",
  "description": "",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "boilerplater.pickupText",
        "title": "Pickup Text"
      }
    ],
    "keybindings": [
      {
        "command": "boilerplater.pickupText",
        "key": "ctrl+u",
        "mac": "cmd+u",
        "when": "editorTextFocus"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./ && shx cp node_modules/sql.js/dist/sql-wasm.wasm ./out/database && shx cp node_modules/sql.js/dist/sql-wasm.js ./out/database",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.20.0",
    "@types/sql.js": "^1.4.11",
    "@types/vscode": "^1.120.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "shx": "^0.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "sql.js": "^1.14.1"
  }
}
