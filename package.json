{
  "name": "boilerplater",
  "displayName": "Br-Zueira's Boilerplater",
  "publisher": "br-zueira",
  "description": "Extension to storage boilerplate snippets so they can be easily reused later",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "boilerplater.pickupText",
        "title": "Boilerplater: Pickup Text"
      },
      {
        "command": "boilerplater.openWebView",
        "title": "Boilerplater: Open Web View"
      }
    ],
    "keybindings": [
      {
        "command": "boilerplater.pickupText",
        "key": "ctrl+u",
        "mac": "cmd+u",
        "when": "editorTextFocus"
      },
      {
        "command": "boilerplater.openWebView",
        "key": "ctrl+alt+u",
        "mac": "cmd+alt+u"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "node build.mjs",
    "watch": "node build.mjs --watch",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.20.0",
    "@types/sql.js": "^1.4.11",
    "@types/vscode": "^1.120.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.28.1",
    "esbuild-plugin-copy": "^2.1.1",
    "eslint": "^9.39.3",
    "shx": "^0.4.0",
    "sql.js": "^1.14.1",
    "tom-select": "^2.6.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
